# Firebase (Console: Project settings > General / Service accounts)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Service account: use o CAMINHO do arquivo .json (recomendado) ou o JSON em uma linha
# Opção 1: baixe o .json no Firebase Console e coloque na raiz do projeto
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Opção 2: cole o JSON inteiro em uma linha (aspas escapadas no .env podem dar problema)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Google OAuth (para login sem popup)
# Firebase Console → Authentication → Sign-in method → Google → Web SDK configuration
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# URL do backend (padrão: http://localhost:3100)
BACKEND_URL=http://localhost:3100
